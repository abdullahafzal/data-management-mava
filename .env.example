# Copy to `.env` on the server (never commit real `.env`)

SECRET_KEY=change-me-generate-with-python-secrets
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

OUTSCRAPER_API_KEY=
MILLIONVERIFIER_API_KEY=
SMARTLEAD_API_KEY=
PHONE_VALIDATION_API_KEY=
SIMPLETEXTING_API_KEY=
GHL_API_KEY=
GHL_LOCATION_ID=
XVERIFY_DOMAIN=
# Set true when XVerify is ready: enables Phone Verifier → SimpleTexting in Process next
XVERIFIER_PROCESS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS S3 — see docs/S3_SETUP.md (leave USE_S3=false until bucket + keys are ready)

